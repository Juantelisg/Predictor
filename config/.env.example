# The Odds API — https://the-odds-api.com/
# Free tier: 500 req/month. Paid tiers for higher volume.
# Renombrar este archivo a `.env` y completar con tu API key real.
THE_ODDS_API_KEY=your_key_here

# Polymarket (solo si vas a operar trades, no para lectura)
POLYMARKET_PRIVATE_KEY=

# Kalshi (opcional)
KALSHI_API_KEY=
KALSHI_API_SECRET=
