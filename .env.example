# Copiá este archivo a .env y completá los valores reales.
# Nunca commiteés .env — ya está en .gitignore.

# Anthropic (requerido para las lecturas de tickets)
ANTHROPIC_API_KEY=sk-ant-...

# The Odds API (opcional - 500 req/mes gratis en https://the-odds-api.com)
THE_ODDS_API_KEY=

# Linemate (opcional - si tenés key propia)
LINEMATE_API_KEY=

# Entorno (local | production)
ENV=local

# Puerto del servidor (Render lo inyecta automático como PORT)
PORT=8900
